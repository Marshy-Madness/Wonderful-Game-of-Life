# Copy this file to `.env` in the same directory as `docker-compose.yml`, then edit
# HOST_DATA_PATH to a folder on your host where game data (`state.json`) should live.
#
#   cp .env.example .env
#
# Docker maps this path to `/data` inside the container. Use an absolute path on
# Linux (e.g. under /mnt/...) or a path that works on your OS.

HOST_DATA_PATH=./data
